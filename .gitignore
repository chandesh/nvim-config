# ══════════════════════════════════════════════════════════════════
#  Neovim vim.pack Configuration — .gitignore
#  Only Lua config files and shell scripts belong in this repo.
#  Everything below is generated at setup time via install.sh/:PI
# ══════════════════════════════════════════════════════════════════

# ── PLUGINS (cloned by install.sh/:PI — never commit) ────────────
pack/

# ── COMPILED EXTENSIONS (built from source during install) ───────
**/*.so
**/*.dylib
**/*.dll
**/build/
**/target/

# ── LUA BYTECODE (generated by Neovim at runtime) ────────────────
*.luac

# ── MASON (LSP servers, DAP adapters, linters) ──────────────────
# Stored in ~/.local/share/nvim/mason/ not here, but in case:
mason/

# ── TREESITTER PARSERS (downloaded by :TSUpdate) ─────────────────
parser/
**/*.wasm

# ── LOG FILES ────────────────────────────────────────────────────
*.log
startuptime*
nvim_log*

# ── SWAP / BACKUP / UNDO FILES ───────────────────────────────────
*.swp
*.swo
*~
*.bak
*.un~
.netrwhist
Session.vim
*.shada
.viminfo

# ── LAZY.VIM REMNANTS (migration cleanup) ────────────────────────
lazy-lock.json
.lazy/

# ── MACHINE-LOCAL OVERRIDES ──────────────────────────────────────
lua/config-local.lua
lua/plugins-local.lua
after/plugin/local.lua
.vimrc.local

# ── LSP / TOOLING CACHES ─────────────────────────────────────────
.tags
tags
tags-*

# ── OS / EDITOR ARTIFACTS ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
*.orig

# ── GRAPHIFY (code analysis output) ──────────────────────────────
.graphify*
graphify-out/

# ── PYTHON ───────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── NODE (copilot or other node deps) ────────────────────────────
node_modules/

# ── CACHE / TEMP ─────────────────────────────────────────────────
.cache/
cache/
*.tmp
/tmp/
